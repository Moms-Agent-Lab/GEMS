# ─────────────────────────────────────────────────────────────────────────────
# ComfyClaw — environment configuration template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM provider (required — pick ONE of the options below) ──────────────────
#
# ComfyClaw routes every LLM call through [litellm], so you can use any
# OpenAI-compatible endpoint (Anthropic, OpenAI, NVIDIA NIM, Azure OpenAI, …)
# by setting three env vars:
#
#   LLM_MODEL       litellm-format model string (see examples below)
#   LLM_API_KEY     provider API key
#   LLM_API_BASE    base URL (only for non-default / OpenAI-compatible gateways)
#
# If `LLM_API_KEY` is not set, the runner falls back to `ANTHROPIC_API_KEY`.
# The `experiments/run_benchmark.py` entrypoint auto-loads this `.env` file,
# so values here are picked up without extra `export`s.
#
# The `openai/` prefix in `LLM_MODEL` tells litellm to use the OpenAI-compatible
# HTTP API; everything after that prefix is sent verbatim as the `model` field
# to the endpoint. So `openai/azure/openai/gpt-5.4` calls `LLM_API_BASE`
# with `model="azure/openai/gpt-5.4"`.
#
# ── Option A · Anthropic (default, what most of the repo is tuned for) ───────

ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL defaults to "anthropic/claude-sonnet-4-5" when unset.

# ── Option B · NVIDIA Inference API (hosts GPT, Claude, Gemini, Llama, …) ────
#
# 1. Grab a key from https://build.nvidia.com/ (NGC → API Keys).
# 2. Pick a model the key can actually access. To list the candidates:
#      curl -sS https://inference-api.nvidia.com/v1/models \
#        -H "Authorization: Bearer $LLM_API_KEY" | jq -r '.data[].id'
#    A single probe tells you whether a specific model is allowed:
#      curl -sS -X POST https://inference-api.nvidia.com/v1/chat/completions \
#        -H "Authorization: Bearer $LLM_API_KEY" -H "Content-Type: application/json" \
#        -d '{"model":"azure/openai/gpt-5.4","messages":[{"role":"user","content":"ping"}],"max_tokens":8}'
#    A 401 `key_model_access_denied` means your key tier doesn't include that model.
# 3. Uncomment and fill in:
#
# LLM_API_KEY=nvapi-...
# LLM_API_BASE=https://inference-api.nvidia.com
# LLM_MODEL=openai/azure/openai/gpt-5.4        # OpenAI GPT-5.4 via Azure
# LLM_MODEL=openai/azure/openai/gpt-4o         # OpenAI GPT-4o
# LLM_MODEL=openai/azure/openai/gpt-4.1        # OpenAI GPT-4.1
# LLM_MODEL=openai/azure/openai/o3             # OpenAI o3 reasoning
# LLM_MODEL=openai/azure/anthropic/claude-sonnet-4-5  # Claude via NVIDIA
# LLM_MODEL=openai/nvcf/meta/llama-3.3-70b-instruct   # Llama-3.3-70B (free tier)
# LLM_MODEL=openai/nvcf/openai/gpt-oss-120b           # GPT-OSS-120B (free tier)

# ── Option C · OpenAI directly ───────────────────────────────────────────────
#
# LLM_API_KEY=sk-...
# LLM_MODEL=openai/gpt-4o
# LLM_MODEL=openai/gpt-5
# LLM_API_BASE is left unset — litellm will hit api.openai.com by default.

# ── Option D · Azure OpenAI (your own deployment) ────────────────────────────
#
# LLM_API_KEY=<azure-key>
# LLM_API_BASE=https://<resource>.openai.azure.com
# LLM_MODEL=azure/<your-deployment-name>
# AZURE_API_VERSION=2024-08-01-preview


# ── ComfyUI connection ────────────────────────────────────────────────────────

# host:port of the running ComfyUI server.
# ComfyUI Desktop default is 127.0.0.1:8188; some versions use 8000.
COMFYUI_ADDR=127.0.0.1:8188

# Absolute path to your ComfyUI installation directory.
# Used only by `comfyclaw install-node`.
# Defaults to ~/Documents/ComfyUI if not set.
COMFYUI_DIR=~/Documents/ComfyUI

# ── NVIDIA-hosted OpenAI models (via litellm OpenAI-compatible endpoint) ─────
LLM_API_KEY=sk-2tOLuRFJRamq7iZPtWIbGQ
LLM_API_BASE=https://inference-api.nvidia.com
LLM_MODEL=openai/azure/openai/gpt-5.4

# ── Image generation model ────────────────────────────────────────────────────

# Pin the ComfyUI checkpoint / UNET to a specific model.
# This name is written into all CheckpointLoaderSimple / UNETLoader nodes in the
# workflow and re-applied after every agent topology change, so the model can
# never accidentally be swapped out.
#
# Use exactly the name that appears in ComfyUI's model dropdown, e.g.:
#   HuggingFace-style path:  Qwen/Qwen-Image-2512
#   Local safetensors file:  realisticVisionV51.safetensors
#
# Leave commented / empty to use whatever model the workflow already contains.
# COMFYCLAW_IMAGE_MODEL=Qwen/Qwen-Image-2512


# ── Agent / harness tuning ────────────────────────────────────────────────────

# Model used by the `comfyclaw` CLI for both the agent and the verifier.
# Only applies to the CLI (`comfyclaw run …`); `experiments/run_benchmark.py`
# reads `LLM_MODEL` above instead.
# Recommended: claude-sonnet-4-5  (balance of speed and quality)
# Faster/cheaper: claude-haiku-4-5
COMFYCLAW_MODEL=claude-sonnet-4-5

# Maximum agent–generate–verify iterations per run.
COMFYCLAW_MAX_ITERATIONS=3

# Stop early when the verifier score reaches this value (0.0–1.0).
COMFYCLAW_THRESHOLD=0.85

# Verifier score weights as "req_weight,detail_weight" (must sum to 1.0).
# req_weight   = weight for yes/no requirement checks
# detail_weight = weight for holistic quality score from region analysis
COMFYCLAW_SCORE_WEIGHTS=0.6,0.4

# When true (default), each iteration starts from the best workflow snapshot
# produced so far, so topology changes (LoRA, ControlNet, …) accumulate.
# Set to false to reset to the base workflow every iteration.
COMFYCLAW_EVOLVE_FROM_BEST=true


# ── Live sync (WebSocket) ─────────────────────────────────────────────────────

# TCP port the Python SyncServer listens on.
# The ComfyClaw-Sync ComfyUI extension connects to this port.
# Set to 0 to disable live sync entirely.
COMFYCLAW_SYNC_PORT=8765


# ── Skills ────────────────────────────────────────────────────────────────────

# Path to a directory of custom SKILL.md files.
# Leave blank to use the built-in skills bundled with the package.
# COMFYCLAW_SKILLS_DIR=/path/to/my_skills
